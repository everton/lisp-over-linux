# gen_init_cpio description for the SBCL-as-init rootfs (separate initrd).
# Build it by hand into a .cpio with the kernel's usr/gen_init_cpio.

# --- directories: mount points + library search paths + /tmp ---
dir  /dev                       0755 0 0
dir  /proc                      0755 0 0
dir  /sys                       0755 0 0
dir  /tmp                       1777 0 0
dir  /sbin                      0755 0 0
dir  /lib64                     0755 0 0
dir  /usr                       0755 0 0
dir  /usr/lib                   0755 0 0
dir  /usr/lib/x86_64-linux-gnu  0755 0 0

# --- device nodes: stdio works even before devtmpfs is mounted ---
nod  /dev/console 0600 0 0 c 5 1
nod  /dev/null    0666 0 0 c 1 3
nod  /dev/tty     0666 0 0 c 5 0

# Source paths below are RELATIVE to the project root — build.sh runs
# gen_init_cpio from there, so no machine-specific absolute path appears here.

# --- the C preinit is /init (mounts fs incl. /tmp, then execs the Lisp) ---
file /init      initramfs/preinit   0755 0 0

# --- the SBCL standalone image (supervisor + worker in one binary) ---
file /sbin/lisp initramfs/lisp-init 0755 0 0

# --- the Land-of-Lisp alien sprite: raw RGBA, 256x150, top-to-bottom ---
# (generated from lisplogo_alien_256.png: `convert alien256.png -depth 8 RGBA:alien.rgba`)
file /alien.rgba initramfs/alien.rgba 0644 0 0

# --- glibc runtime the SBCL binary needs (exact paths the loader expects) ---
file /lib64/ld-linux-x86-64.so.2         /usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 0755 0 0
file /usr/lib/x86_64-linux-gnu/libc.so.6 /usr/lib/x86_64-linux-gnu/libc.so.6            0755 0 0
file /usr/lib/x86_64-linux-gnu/libm.so.6 /usr/lib/x86_64-linux-gnu/libm.so.6            0755 0 0
