# =====================================================================
# What git should NOT track in the micro-distro.
# Rule: ignore anything build.sh regenerates, plus test/run scratch.
# The SOURCES (*.org, *.c, *.lisp, *.list, build.sh, the alien assets,
# and the snapshotted kernel config under kernel/) ARE tracked.
# (NB: git only treats '#' as a comment at the START of a line — no
#  trailing inline comments, or the whole line becomes a pattern.)
# =====================================================================

# --- Build artifacts (regenerated by build.sh) ---
# compiled from preinit.c:
initramfs/preinit
# SBCL saved image (save-lisp-and-die), ~36M:
initramfs/lisp-init
# generated cpio rootfs, ~38M:
iso_root/initramfs.cpio
# a copy of the kernel bzImage, ~2M:
iso_root/efi/boot/bootx64.efi
# compiled from host-client/lol-repl-client.c (host tool; build with cc):
host-client/lol-repl-client

# --- QEMU test / run scratch (build.sh --run) ---
ovmf_vars_test.fd
serial.log
screen.ppm
screen.png

# --- External source trees (machine-local; materialized by deps.sh) ---
# ./linux and ./sbcl are symlinks to a Linux kernel tree and an SBCL tree.
# They are huge, version-specific, and per-machine — never committed.
/linux
/sbcl
# default location deps.sh downloads sources into (if not linking existing ones):
/sources/

# --- Local tooling state ---
.claude/settings.local.json
